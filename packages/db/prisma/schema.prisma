generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  student
  admin
}

enum StreamStatus {
  active
  archived
}

enum SessionStatus {
  draft
  planned
  live
  done
  cancelled
}

// Статус встречи 1-на-1 (эпик «Встречи 1-на-1», #154). Зеркало SessionStatus
// без draft — у встречи нет черновика (создаётся сразу запланированной).
enum MeetingStatus {
  planned
  live
  done
  cancelled
}

enum ProgramType {
  course
  intensive
  mentorship
}

enum AssignmentType {
  short
  long
}

enum StudentAssignmentStatus {
  assigned
  submitted
  reviewed
  needs_revision
}

enum ThreadEntryType {
  text
  file
  audio
  link
  comment
  note
}

enum ConversationType {
  student
  staff
  stream
  cohort
}

enum WalletTxKind {
  topup
  debit
}

// Статус заявки студента на пополнение баланса по скрину оплаты.
// pending — ждёт проверки админом; approved — зачислено; rejected — отклонено.
enum TopUpRequestStatus {
  pending
  approved
  rejected
}

// Статус начисления студенту за группу (ledger «Оплата и баланс», платёжный план группы).
// open — начисление открыто (не погашено полностью); paid — погашено целиком; refunded — возвращено админом.
enum ChargeStatus {
  open
  paid
  refunded
}

enum NotificationType {
  lesson_published
  assignment_created
  deadline_reminder
  thread_entry
  assignment_submitted
  assignment_reviewed
  schedule_entry_created
  topup_requested
  mentorship_charge_upcoming
  mentorship_charge_debt
  // Студент зачислен в группу (поток). Уведомление преподавателю/владельцу группы.
  // Эпик «Уведомления преподавателю». События «сдал задание» и «сообщение в чате»
  // переиспользуют существующие assignment_submitted / thread_entry — новые типы не нужны.
  student_enrolled
}

// Тип биллинга группы (дискриминатор): one_time — разовая оплата за участие
// (Stream.priceKopecks), monthly — ежемесячное авто-списание за менторскую группу
// (Stream.monthlyPriceKopecks в день Stream.billingDayOfMonth). Эпик «Авто-списание
// за менторские группы».
enum StreamBillingType {
  one_time
  monthly
}

// Тип начисления (атрибуция): one_time — разовое начисление за участие в группе;
// monthly — ежемесячное менторское начисление (с привязкой к периоду Charge.periodKey).
// Позволяет отличать менторские списания от разовых в статистике/отчётах.
enum ChargeKind {
  one_time
  monthly
}

// Тип согласия пользователя (Волна 1 «правовой минимум»): offer — акцепт оферты;
// personalData — согласие на обработку ПДн; serviceNotifications — сервисные
// уведомления; marketing — рекламно-информационные рассылки;
// personalDataPolicy — ознакомление с «Политикой обработки персональных данных»
// (документ personal-data-policy). Значения camelCase — по утверждённому ТЗ
// (фиксируются в API при регистрации/входе).
enum ConsentType {
  offer
  personalData
  serviceNotifications
  marketing
  personalDataPolicy
}

// Действие по согласию: granted — дано, revoked — отозвано. История append-only:
// текущий статус согласия = последняя запись по (userId, consentType).
enum ConsentAction {
  granted
  revoked
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String
  role                UserRole  @default(student)
  name                String
  // Фамилия — НОВОЕ отдельное nullable-поле (Волна 1 «правовой минимум»).
  // Существующее name НЕ трогаем и не мигрируем (там у старых пользователей
  // может лежать что угодно: имя, имя+фамилия, ник).
  lastName            String?
  // Телефон — nullable строка; формат (международный) валидируется на уровне API.
  phone               String?
  avatarKey           String?
  isActive            Boolean   @default(true)
  mustChangePassword  Boolean   @default(false)
  balanceKopecks      Int       @default(0)
  // Единый флаг «демо/служебный аккаунт»: НЕ списывать деньги (ни регулярно, ни разово)
  // И скрывать из статистики. Один флаг на пользователе (не per-enrollment). Эпик
  // «Авто-списание за менторские группы».
  isDemo              Boolean   @default(false)
  inviteToken         String?   @unique
  inviteExpiresAt     DateTime?
  resetToken          String?   @unique
  resetTokenExpiresAt DateTime?
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  refreshTokens           RefreshToken[]
  studentAssignments      StudentAssignment[]
  studentConversation     Conversation?
  authoredEntries         ConversationEntry[]      @relation("AuthoredEntries")
  conversationReads       ConversationRead[]
  studentProfile          StudentProfile?
  teacherNotes            TeacherNote[]            @relation("AuthoredNotes")
  studentNotes            TeacherNote[]            @relation("StudentNotes")
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  pushSubscriptions       PushSubscription[]
  apiKeys                 ApiKey[]
  enrollments             StreamEnrollment[]
  taughtLessons           LessonTeacher[]
  ownedStreams            Stream[]                 @relation("StreamOwner")
  ownedPrograms           Program[]                @relation("ProgramOwner")
  walletTransactions      WalletTransaction[]      @relation("WalletTxUser")
  zoomIntegration         ZoomIntegration?
  telegramIntegration     TelegramIntegration?
  topUpRequests           TopUpRequest[]           @relation("TopUpAuthor")
  reviewedTopUps          TopUpRequest[]           @relation("TopUpReviewer")
  sessionAttendance       SessionAttendance[]
  charges                 Charge[]                 @relation("ChargeUser")
  createdCharges          Charge[]                 @relation("ChargeCreatedBy")
  // «Динамика ученика» (приватный инструмент преподавателя). Roadmap-шапка — одна
  // на ученика; записи ленты — много. Авторство/правки фиксируем через updatedBy/author.
  studentDynamic          StudentDynamic?          @relation("StudentDynamicStudent")
  updatedDynamics         StudentDynamic[]         @relation("StudentDynamicUpdatedBy")
  dynamicEntries          StudentDynamicEntry[]    @relation("StudentDynamicEntryStudent")
  authoredDynamicEntries  StudentDynamicEntry[]    @relation("StudentDynamicEntryAuthor")
  // Лог активности студента: прогресс просмотра видео уроков (Этап A).
  videoViews              VideoView[]
  // Лог активности студента: обращения к материалам урока (просмотр/скачивание).
  materialAccesses        MaterialAccess[]
  // Юридические согласия пользователя (append-only история, Волна 1 «правовой минимум»).
  consents                UserConsent[]
  // Встречи 1-на-1 (эпик «Встречи 1-на-1», #154): как преподаватель и как студент.
  meetingsAsTeacher       Meeting[]                @relation("MeetingTeacher")
  meetingsAsStudent       Meeting[]                @relation("MeetingStudent")
}

model ApiKey {
  id         String    @id @default(uuid())
  name       String
  keyPrefix  String
  keyHash    String    @unique
  userId     String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Stream {
  id                  String            @id @default(uuid())
  name                String
  status              StreamStatus      @default(active)
  ownerId             String?
  programId           String?
  // Публичный токен постоянной инвайт-ссылки вступления в поток (одна ссылка на поток).
  // null = ссылка ещё не сгенерирована. НЕ путать с User.inviteToken — это другой механизм.
  joinToken           String?           @unique
  // Когда токен сгенерирован/перевыпущен (для UI и аудита).
  joinTokenAt         DateTime?
  // Внешняя ссылка на оплату группы (платёжная страница банка/сервиса), которую
  // админ вставляет вручную. null = ссылка не задана. Это просто внешний URL —
  // система НЕ отслеживает факт оплаты по нему (баланс/долг админ отмечает вручную).
  paymentUrl          String?
  // Платёжный план группы: цена за участие в копейках. null = план не задан
  // (студенты не начисляются автоматически). Эпик «Оплата и баланс».
  // Смысл — РАЗОВАЯ цена (billingType = one_time).
  priceKopecks        Int?
  // Тип биллинга группы: one_time (разовая, priceKopecks) либо monthly (ежемесячное
  // авто-списание, monthlyPriceKopecks в день billingDayOfMonth). Эпик
  // «Авто-списание за менторские группы».
  billingType         StreamBillingType @default(one_time)
  // Месячная сумма авто-списания в копейках (смысл при billingType = monthly).
  monthlyPriceKopecks Int?
  // День месяца для авто-списания (1–28; значения 29–31 cron клампит к последнему дню
  // месяца — в БД хранится как есть, валидация на стороне приложения).
  billingDayOfMonth   Int?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  owner            User?              @relation("StreamOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  program          Program?           @relation(fields: [programId], references: [id], onDelete: SetNull)
  sessions         Session[]
  enrollments      StreamEnrollment[]
  conversations    Conversation[]
  charges          Charge[]
  videoViews       VideoView[]
  materialAccesses MaterialAccess[]
  lessonVideos     LessonVideo[]

  @@index([ownerId])
  @@index([programId])
}

model StreamEnrollment {
  id        String   @id @default(uuid())
  streamId  String
  userId    String
  createdAt DateTime @default(now())

  stream Stream @relation(fields: [streamId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([streamId, userId])
  @@index([streamId])
  @@index([userId])
}

model Lesson {
  id                    String          @id @default(uuid())
  title                 String
  videoUrl              String?
  videoKey              String?
  summary               String?
  notes                 String?
  materials             Json            @default("[]")
  sortOrder             Int             @default(0)
  hasAssignment         Boolean         @default(false)
  assignmentTitle       String?
  assignmentDescription String?
  assignmentCriteria    String?
  assignmentType        AssignmentType?
  assignmentTags        String[]        @default([])
  assignmentMaterials   Json            @default("[]")
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  teachers            LessonTeacher[]
  programLessons      ProgramLesson[]
  sessions            Session[]
  conversationEntries ConversationEntry[]
  videos              LessonVideo[]
  materialAccesses    MaterialAccess[]
}

// Видеозапись урока. У одного урока может быть несколько видео (части записи или
// разные источники). Каждое видео — ЛИБО загруженный файл (videoKey в S3), ЛИБО
// внешняя ссылка (videoUrl, YouTube/Vimeo). title и sortOrder задают подпись и
// порядок показа. Существующее одиночное видео Lesson.videoKey/videoUrl
// скопировано сюда миграцией; сами поля Lesson пока оставлены для легаси-экранов.
model LessonVideo {
  id        String   @id @default(uuid())
  lessonId  String
  // Привязка видео к потоку (изоляция материалов урока по группам).
  // null  = общее учебное видео урока («метод»), видно студентам ВСЕХ потоков;
  // задан = видео видно ТОЛЬКО студентам этого потока.
  // onDelete: SetNull — при удалении потока видео НЕ теряем, оно становится общим.
  streamId  String?
  title     String?
  videoKey  String?
  videoUrl  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  stream Stream? @relation(fields: [streamId], references: [id], onDelete: SetNull)

  videoViews VideoView[]

  @@index([lessonId])
  // Фильтр «общие (streamId IS NULL) + видео конкретного потока» для одного урока.
  @@index([lessonId, streamId])
}

// Прогресс просмотра конкретного загруженного видео урока конкретным студентом
// в контексте конкретного потока (Этап A эпика «Лог активности студента»).
// Один ряд на тройку (студент, видео, поток) — апсёртится клиентом по биениям плеера.
//
// watchedSec — сумма УНИКАЛЬНЫХ просмотренных секунд (по UNION интервалов, без учёта
//   повторов); watchedPercent = watchedSec / durationSec, 0..100. watchedIntervals —
//   смёрженные интервалы [[start,end],...] для честного пересчёта при следующих биениях.
// lastPositionSec / sessionsCount / totalPlayedSec — задел под Уровень 2 («продолжить
//   с места», аналитика по заходам и суммарному времени с повторами).
// completedAt — когда впервые достигнут порог «досмотрел» (>=90%). lastWatchedAt —
//   время последнего прогресса (обновляется приложением при апсёрте; сорт в ленте активности).
//
// onDelete: всё Cascade — запись о просмотре теряет смысл без студента/видео/потока.
model VideoView {
  id               String    @id @default(uuid())
  studentId        String
  lessonVideoId    String
  streamId         String
  watchedSec       Int       @default(0)
  watchedPercent   Int       @default(0)
  lastPositionSec  Int       @default(0)
  durationSec      Int?
  watchedIntervals Json      @default("[]")
  sessionsCount    Int       @default(0)
  totalPlayedSec   Int       @default(0)
  completedAt      DateTime?
  lastWatchedAt    DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  student     User        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lessonVideo LessonVideo @relation(fields: [lessonVideoId], references: [id], onDelete: Cascade)
  stream      Stream      @relation(fields: [streamId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonVideoId, streamId])
  @@index([studentId, lastWatchedAt])
  @@index([lessonVideoId, streamId])
}

// Журнал обращений студента к материалам урока (просмотр/скачивание) в контексте
// потока — append-only лента активности (Этап A эпика «Лог активности студента»).
// В отличие от VideoView это НЕ агрегат, а журнал: каждое обращение = отдельная
// строка, @@unique НЕТ намеренно (так решил заказчик) — повторные просмотры/скачивания
// одного файла плодят новые записи, по ним строится хронология действий.
//
//   s3Key      — ключ файла-материала в FileStorage/S3 (материалы урока хранятся в
//                Lesson.materials как JSON и могут меняться — поэтому ссылаемся на ключ);
//   fileName   — СНИМОК имени файла на момент обращения (для отображения в ленте, даже
//                если материал позже переименован/удалён из Lesson.materials);
//   accessType — тип обращения: 'viewed' | 'downloaded' (строкой, без enum — по конвенции
//                проекта, ср. VideoView и SessionAttendance.source/status);
//   accessedAt — время обращения, по нему сортировка в ленте активности.
//
// onDelete: studentId/lessonId/streamId — все Cascade: запись об обращении не имеет
//   смысла без студента, урока или потока, поэтому удаляется вместе с любым из них.
model MaterialAccess {
  id         String   @id @default(uuid())
  studentId  String
  lessonId   String
  streamId   String
  s3Key      String
  fileName   String
  accessType String // 'viewed' | 'downloaded'
  accessedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson  Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  stream  Stream @relation(fields: [streamId], references: [id], onDelete: Cascade)

  @@index([studentId, accessedAt])
  @@index([lessonId, streamId])
}

model LessonTeacher {
  id        String   @id @default(uuid())
  lessonId  String
  userId    String
  createdAt DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lessonId, userId])
  @@index([lessonId])
  @@index([userId])
}

model Program {
  id           String      @id @default(uuid())
  name         String
  type         ProgramType @default(course)
  ownerId      String?
  whatYouLearn String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  owner          User?           @relation("ProgramOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  programLessons ProgramLesson[]
  streams        Stream[]

  @@index([ownerId])
}

model ProgramLesson {
  id        String   @id @default(uuid())
  programId String
  lessonId  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  lesson  Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([programId, lessonId])
  @@index([programId])
  @@index([lessonId])
}

model Session {
  id         String        @id @default(uuid())
  streamId   String
  lessonId   String
  status     SessionStatus @default(planned)
  date       DateTime?     @db.Date
  startTime  String?
  meetingUrl String?
  videoUrl   String?
  videoKey   String?
  dueDate    DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  // Zoom-созвоны (Волна 2). Все поля nullable — фича аддитивна.
  zoomMeetingId   String? // id встречи Zoom для сопоставления входящего вебхука с занятием
  zoomMeetingUuid String? // UUID встречи Zoom — нужен для meeting_summary API (числовой id он не принимает)
  recordingStatus String? // статус записи: none | pending | processing | ready | failed (строкой, без enum)
  recordingError  String? // текст ошибки автозагрузки записи (для UI)
  summary         String? // итоги/конспект КОНКРЕТНОГО занятия потока (отдельно от Lesson.summary)
  summarySource   String? // источник summary: 'zoom_ai' | 'manual'

  // Итоги + Транскрипт занятия (Ф1.2 + Ф2.6). Все поля nullable — фича аддитивна.
  summaryStatus         String? // статус итогов: none | pending | processing | ready | failed (строкой, без enum)
  transcriptStatus      String? // статус транскрипта: none | pending | processing | ready | failed
  transcriptVttKey      String? // ключ S3 для сырого .vtt транскрипта
  transcriptTxtKey      String? // ключ S3 для очищенного .txt транскрипта
  transcriptError       String? // текст ошибки забора транскрипта (для препода/админа)
  transcriptRequestedAt DateTime? // когда запросили транскрипт (для увеличенного таймаута до failed — приходит позже записи)
  recordingRequestedAt  DateTime? // когда запись запрошена/ожидается (ставится на meeting.ended) — для таймаута «формируется → недоступно»
  summaryRequestedAt    DateTime? // когда итоги запрошены/ожидаются (на meeting.ended) — для таймаута состояния итогов

  stream             Stream              @relation(fields: [streamId], references: [id], onDelete: Cascade)
  lesson             Lesson              @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  studentAssignments StudentAssignment[]
  attendance         SessionAttendance[]

  @@unique([streamId, lessonId])
  @@index([streamId])
  @@index([lessonId])
  @@index([status, date])
  @@index([zoomMeetingId])
}

// Встреча 1-на-1 преподавателя со студентом (эпик «Встречи 1-на-1», #154).
// Лёгкая отдельная сущность (НЕ Session): у 1-на-1 нет stream/lesson. Zoom/запись/
// итоги/транскрипт-поля ЗЕРКАЛЯТ Session — те же имена/типы, чтобы переиспользовать
// обработчики (lib/zoom-recording.ts, zoom-webhooks). Все Zoom-поля nullable —
// фича аддитивна. Изоляция two-party: видят только teacher и student.
model Meeting {
  id         String        @id @default(uuid())
  teacherId  String
  studentId  String
  title      String?
  status     MeetingStatus @default(planned)
  date       DateTime?     @db.Date
  startTime  String?
  meetingUrl String?
  videoUrl   String?
  videoKey   String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  // Zoom-созвоны — те же имена полей, что у Session, для общих обработчиков.
  zoomMeetingId   String? @unique // id встречи Zoom для сопоставления входящего вебхука с встречей
  zoomMeetingUuid String? // UUID встречи Zoom — нужен для meeting_summary API (числовой id он не принимает)
  recordingStatus String? // статус записи: none | pending | processing | ready | failed (строкой, без enum)
  recordingError  String? // текст ошибки автозагрузки записи (для UI)
  summary         String? // итоги/конспект встречи
  summarySource   String? // источник summary: 'zoom_ai' | 'manual'

  // Итоги + Транскрипт встречи — зеркало Session. Все поля nullable — фича аддитивна.
  summaryStatus         String? // статус итогов: none | pending | processing | ready | failed
  transcriptStatus      String? // статус транскрипта: none | pending | processing | ready | failed
  transcriptVttKey      String? // ключ S3 для сырого .vtt транскрипта
  transcriptTxtKey      String? // ключ S3 для очищенного .txt транскрипта
  transcriptError       String? // текст ошибки забора транскрипта
  transcriptRequestedAt DateTime? // когда запросили транскрипт
  recordingRequestedAt  DateTime? // когда запись запрошена/ожидается (на meeting.ended)
  summaryRequestedAt    DateTime? // когда итоги запрошены/ожидаются (на meeting.ended)

  teacher User @relation("MeetingTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  student User @relation("MeetingStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([studentId])
  @@index([status, date])
  @@index([zoomMeetingId])
}

// Посещаемость занятия потока (B5, фаза 2). Две природы записей:
//   source='zoom_report' — авто-забор из Zoom report participants API (один ряд на
//     участника встречи; userId проставляется при сопоставлении по email со студентом потока);
//   source='manual'      — ручная отметка админом (всегда привязана к студенту userId).
// status и source хранятся строкой без enum — по конвенции проекта (ср. Session.recordingStatus
// "строкой, без enum" и Session.summarySource 'zoom_ai' | 'manual').
//   source: 'zoom_report' | 'manual'
//   status: 'present' | 'absent'  (для zoom-участника по умолчанию 'present')
//
// ДЕДУП / ИДЕМПОТЕНТНОСТЬ — два непересекающихся частичных уникальных индекса (см. migration.sql):
//   1) UNIQUE (sessionId, zoomParticipantId) WHERE zoomParticipantId IS NOT NULL
//      — авто-забор апсёртит по (sessionId, zoomParticipantId), повторные синки не плодят дубли.
//   2) UNIQUE (sessionId, userId) WHERE source='manual'
//      — ручная отметка одна на (студент, занятие); upsert обновляет статус.
// Индексы НЕ конфликтуют: zoom-гость без userId не нарушает (2), а ручная запись без
// zoomParticipantId не нарушает (1). Один и тот же студент может иметь и zoom-ряд
// (сопоставленный), и ручной ряд — это допустимо; финальный статус занятия выводит
// приложение (manual имеет приоритет над zoom_report).
model SessionAttendance {
  id        String  @id @default(uuid())
  sessionId String
  // Сопоставленный студент. null = несопоставленный zoom-гость (нет userId по email).
  userId    String?
  source    String // 'zoom_report' | 'manual'
  status    String  @default("present") // 'present' | 'absent'
  // ряд хоста встречи (преподаватель), не студент-гость — не сопоставляется и не считается гостем
  isHost    Boolean @default(false)

  // Данные из Zoom report participants API (все nullable).
  zoomParticipantId String? // participant id Zoom (для дедупа авто-забора)
  displayName       String? // имя участника из Zoom
  email             String? // user_email из Zoom (для сопоставления со студентом потока)
  joinedAt          DateTime? // самый ранний join_time
  leftAt            DateTime? // самый поздний leave_time
  durationSec       Int? // суммарная длительность по всем переподключениям, сек

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([userId])
}

model StudentAssignment {
  id             String                  @id @default(uuid())
  sessionId      String
  studentId      String
  status         StudentAssignmentStatus @default(assigned)
  content        String?
  fileUrl        String?
  fileName       String?
  fileSize       Int?
  studentComment String?
  reviewText     String?
  reviewedBy     String?
  submittedAt    DateTime?
  reviewedAt     DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student User    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([studentId])
  @@index([sessionId])
}

model Conversation {
  id        String           @id @default(uuid())
  type      ConversationType
  studentId String?          @unique
  streamId  String?
  createdAt DateTime         @default(now())

  student User?               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  stream  Stream?             @relation(fields: [streamId], references: [id], onDelete: Cascade)
  entries ConversationEntry[]
  reads   ConversationRead[]

  // Один streamId может иметь несколько каналов разных типов:
  // type='stream' (преподский чат потока) и type='cohort' (общий чат потока).
  @@unique([type, streamId])
}

model ConversationEntry {
  id             String          @id @default(uuid())
  conversationId String
  authorId       String
  type           ThreadEntryType @default(text)
  content        String
  metadata       Json?
  lessonId       String?
  createdAt      DateTime        @default(now())
  readAt         DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User         @relation("AuthoredEntries", fields: [authorId], references: [id], onDelete: Cascade)
  lesson       Lesson?      @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([authorId])
}

model ConversationRead {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  lastReadAt     DateTime

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model StudentProfile {
  id                       String    @id @default(uuid())
  studentId                String    @unique
  resume                   String?
  portfolio                String?
  contacts                 Json?
  direction                String?
  questionnaireCompletedAt DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model TeacherNote {
  id        String   @id @default(uuid())
  studentId String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  student User @relation("StudentNotes", fields: [studentId], references: [id], onDelete: Cascade)
  author  User @relation("AuthoredNotes", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  metadata  Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model NotificationPreference {
  id           String           @id @default(uuid())
  userId       String
  type         NotificationType
  emailEnabled Boolean          @default(true)
  pushEnabled  Boolean          @default(true)
  inAppEnabled Boolean          @default(true)
  // Канал Telegram. Дефолт true безопасен: отправка возможна только после привязки
  // (TelegramIntegration.chatId заполнен и enabled); без привязки просто не отправится.
  telegramEnabled Boolean       @default(true)
  updatedAt    DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model FileStorage {
  id        String   @id @default(uuid())
  key       String   @unique
  data      Bytes
  mimeType  String
  fileName  String
  size      Int
  createdAt DateTime @default(now())

  @@index([key])
}

model WalletTransaction {
  id        String       @id @default(uuid())
  userId    String
  amount    Int // в копейках; для topup положительное, для debit положительное (знак определяется kind)
  kind      WalletTxKind
  note      String?
  createdBy String? // имя администратора, сделавшего операцию
  // Начисление за группу, которое гасится этой транзакцией (если есть). Одно начисление
  // может гаситься НЕСКОЛЬКИМИ списаниями — поэтому связь со стороны WalletTransaction
  // (НЕ @unique). Эпик «Оплата и баланс».
  chargeId  String?
  createdAt DateTime     @default(now())
  user      User         @relation("WalletTxUser", fields: [userId], references: [id], onDelete: Cascade)
  charge    Charge?      @relation(fields: [chargeId], references: [id], onDelete: SetNull)

  // Заявка на пополнение, по которой была проведена эта транзакция (если есть).
  topUpRequest TopUpRequest?

  @@index([userId])
  @@index([chargeId])
}

// Заявка студента на пополнение баланса по скриншоту оплаты (Фаза 1 эпика «Оплата и баланс»).
// Студент прикладывает скрин (screenshotKey в S3) и заявленную сумму; админ проверяет и
// одобряет/отклоняет. ИДЕМПОТЕНТНОСТЬ: walletTransactionId @unique гарантирует, что по одной
// заявке проводится НЕ БОЛЕЕ одной транзакции пополнения.
//
// АНТИ-СПАМ (M1): ровно одна заявка в статусе pending на пользователя — гарантируется
// PARTIAL UNIQUE INDEX "TopUpRequest_userId_pending_key" ... WHERE status = 'pending'
// (создаётся сырым SQL в миграции 20260704_topup_pending_unique, т.к. Prisma не умеет
// partial unique в schema). Это страховка БД от TOCTOU-гонки двух параллельных запросов;
// приложение дополнительно делает быстрый findFirst-чек и ловит P2002.
model TopUpRequest {
  id                    String             @id @default(uuid())
  userId                String // студент-автор заявки
  screenshotKey         String // ключ скрина оплаты в S3
  claimedAmountKopecks  Int? // заявленная студентом сумма (копейки)
  status                TopUpRequestStatus @default(pending)
  reviewedById          String? // админ-ревьюер
  reviewedAt            DateTime?
  note                  String? // комментарий студента / резолюция админа
  walletTransactionId   String?            @unique // связь с проведённым пополнением (идемпотентность)
  creditedAmountKopecks Int? // фактически зачислено (копейки)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  user        User               @relation("TopUpAuthor", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy  User?              @relation("TopUpReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  transaction WalletTransaction? @relation(fields: [walletTransactionId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([userId])
}

// Начисление студенту за участие в группе (ledger «Оплата и баланс», платёжный план группы).
// amountKopecks — цена, зафиксированная на момент зачисления студента (даже если позже
// Stream.priceKopecks изменится). paidKopecks — сколько уже погашено списаниями с баланса
// (одно начисление может гаситься несколькими WalletTransaction). status: open → paid после
// полного погашения; refunded — возврат админом. createdById — админ-создатель (для аудита/возврата).
//
// ИДЕМПОТЕНТНОСТЬ (создаётся сырым SQL в миграции, т.к. Prisma не умеет partial unique в schema):
//  - РАЗОВЫЕ (periodKey IS NULL): ровно одно ОТКРЫТОЕ начисление на пару (streamId, userId) —
//    PARTIAL UNIQUE "charge_active_uniq" WHERE status='open' AND periodKey IS NULL. После
//    полного погашения можно создать новое.
//  - МЕСЯЧНЫЕ (periodKey IS NOT NULL): ровно одно начисление на (streamId, userId, periodKey)
//    в любом статусе — PARTIAL UNIQUE "charge_period_uniq" WHERE periodKey IS NOT NULL (долг
//    прошлого месяца НЕ блокирует начисление за новый период).
model Charge {
  id            String       @id @default(uuid())
  streamId      String
  userId        String
  amountKopecks Int // зафиксированная цена на момент зачисления (копейки)
  paidKopecks   Int          @default(0) // сколько уже погашено списаниями (копейки)
  status        ChargeStatus @default(open)
  note          String?
  createdById   String? // админ-создатель начисления (для аудита/возврата)
  // Период месячного начисления в формате 'YYYY-MM' (напр. '2026-05'). null = разовое
  // начисление. Используется для идемпотентности ежемесячного авто-списания
  // (partial unique "charge_period_uniq" по (streamId,userId,periodKey) WHERE periodKey IS NOT NULL).
  periodKey     String?
  // Тип начисления (атрибуция): one_time — разовое, monthly — ежемесячное менторское.
  kind          ChargeKind   @default(one_time)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  stream             Stream              @relation(fields: [streamId], references: [id], onDelete: Cascade)
  user               User                @relation("ChargeUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy          User?               @relation("ChargeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  walletTransactions WalletTransaction[]

  @@index([userId, status])
  @@index([streamId])
}

// Настройки оплаты (синглтон — один ряд с id="singleton"). Куда переводить деньги:
// ссылка/телефон/QR-код (qrFileKey в S3) и текстовая инструкция для студентов.
model PaymentSettings {
  id            String   @id @default("singleton")
  transferUrl   String?
  transferPhone String?
  qrFileKey     String?
  instructions  String?
  updatedById   String?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())
}

// Настройки интеграции с Zoom (Server-to-Server OAuth) — пер-преподаватель:
// у каждого админа/преподавателя свой конфиг (одна строка на userId). Секрет
// клиента хранится зашифрованным (AES-256-GCM) в clientSecretEnc.
model ZoomIntegration {
  id                String    @id @default(uuid())
  userId            String    @unique
  enabled           Boolean   @default(false)
  accountId         String?
  clientId          String?
  clientSecretEnc   String?
  // Webhook Secret Token в зашифрованном виде (шифруется как clientSecretEnc).
  secretTokenEnc    String?
  // Публичный неугадываемый id для персонального URL вебхука (/webhooks/zoom/<webhookId>).
  // Заполняется приложением позже; здесь — просто nullable unique.
  webhookId         String?   @unique
  autoCreateMeeting Boolean   @default(false)
  // email хоста (Zoom-аккаунт, под которым создаются встречи) — для исключения хоста из гостей посещаемости
  hostEmail         String?
  // id пользователя Zoom (из /users/me) — запасной признак хоста, если email скрыт в отчёте
  hostZoomUserId    String?
  lastTestedAt      DateTime?
  lastTestOk        Boolean?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Персональная интеграция пользователя с собственным Telegram-ботом. По образцу
// ZoomIntegration: КАЖДЫЙ преподаватель сам создаёт бота в @BotFather и вводит его
// токен в настройках; токен хранится зашифрованным (как Zoom clientSecretEnc).
// Эпик «Уведомления преподавателю».
// Сценарий: пользователь вводит botToken → платформа валидирует через getMe и
// сохраняет botUsername → пользователь открывает t.me/<botUsername>, жмёт «Старт» →
// платформа разово делает getUpdates по его токену, берёт chatId → дальше уведомления
// шлются через ЕГО токен в ЕГО chatId.
model TelegramIntegration {
  id           String    @id @default(uuid())
  userId       String    @unique
  // Включён ли канал у пользователя. По умолчанию true; реальная отправка возможна
  // только когда заданы botTokenEnc и chatId (бот введён и чат привязан).
  enabled      Boolean   @default(true)
  // Токен бота пользователя (из @BotFather), ЗАШИФРОВАН (lib/crypto, как Zoom). Наружу
  // не отдаётся — только флаг наличия.
  botTokenEnc  String?
  // @username бота (из getMe) — для ссылки t.me/<botUsername> и подписи. Не секрет.
  botUsername  String?
  // Telegram chat id личного чата пользователя с его ботом. Заполняется после привязки.
  chatId       String?
  // Момент успешной привязки чата.
  linkedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Идемпотентность обработки входящих вебхуков Zoom: каждое событие
// записывается с уникальным dedupeKey, чтобы не обрабатывать повторно.
model ZoomWebhookEvent {
  id          String    @id @default(uuid())
  dedupeKey   String    @unique // event + meetingId + recording uuid / хэш payload
  event       String
  status      String    @default("received") // received | processed | failed
  createdAt   DateTime  @default(now())
  processedAt DateTime?
}

// «Динамика ученика» — приватный инструмент преподавателя/админа (ученик НЕ видит).
// Roadmap-шапка: один ряд на ученика, markdown-конспект «с чем пришёл / в процессе /
// с чем ушёл». Записи прогресса хранятся отдельно (StudentDynamicEntry).
model StudentDynamic {
  id          String   @id @default(uuid())
  studentId   String   @unique
  roadmap     String? // markdown «с чем пришёл / в процессе / с чем ушёл»
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student   User  @relation("StudentDynamicStudent", fields: [studentId], references: [id], onDelete: Cascade)
  updatedBy User? @relation("StudentDynamicUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
}

// Лента датированных записей прогресса ученика (markdown). source — задел под Фазу 2
// (Claude-автозаполнение из транскрипта): manual | ai_transcript. lessonId/sessionId —
// необязательная привязка к уроку/проведению (простые nullable-строки без FK).
model StudentDynamicEntry {
  id        String   @id @default(uuid())
  studentId String
  authorId  String?
  content   String // markdown-текст записи
  source    String   @default("manual") // manual | ai_transcript (задел под Фазу 2)
  lessonId  String?
  sessionId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student User  @relation("StudentDynamicEntryStudent", fields: [studentId], references: [id], onDelete: Cascade)
  author  User? @relation("StudentDynamicEntryAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([studentId])
}

// ===== Волна 1 «правовой минимум»: юридические документы и согласия =====

// Реестр юридических документов портала (карточки: оферта, политика ПДн и т.д.).
// САМИ ТЕКСТЫ живут В КОДЕ (markdown) и публикуются через LegalDocumentVersion
// разработчиком; здесь — только реестр. 8 базовых документов создаёт сид (upsert по
// slug, идемпотентно). slug — латиница: offer, personal-data-policy, cookie-policy,
// portal-rules, service-regulations, requisites, pd-consent, marketing-consent.
model LegalDocument {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  createdAt DateTime @default(now())

  versions LegalDocumentVersion[]
}

// Версия юридического документа: иммутабельный снимок markdown-текста (body) с номером
// версии (уникален в рамках документа) и датой публикации. Неизменяемость обеспечивается
// на уровне приложения: API на запись/правку версий НЕ даём. Версии выпускает
// разработчик через prisma/legal-content/manifest.ts: publishLegalVersions() в seed.ts
// создаёт НЕДОСТАЮЩИЕ версии из манифеста, существующие никогда не трогает.
model LegalDocumentVersion {
  id            String   @id @default(uuid())
  documentId    String
  versionNumber Int
  body          String // markdown-текст версии документа
  publishedAt   DateTime @default(now())

  document LegalDocument @relation(fields: [documentId], references: [id], onDelete: Restrict)
  consents UserConsent[]

  @@unique([documentId, versionNumber])
  @@index([documentId])
}

// Согласие пользователя с конкретной ВЕРСИЕЙ документа: append-only журнал (записи не
// апдейтим и не удаляем — это юридическая история; текущий статус = последняя запись по
// userId+consentType). ip/userAgent — снимок контекста на момент действия (userAgent
// обрезается на API); nullable — на случай, если заголовки недоступны (прокси и т.п.).
// Согласия старых пользователей появятся второй волной при входе — схема это позволяет
// (записи просто добавятся позже).
// onDelete: userId — Cascade (физическое удаление пользователя в проекте не практикуется,
// удаление мягкое через deletedAt; при hard-delete ПДн вычищаются вместе с согласиями);
// documentVersionId — Restrict (версию, на которую есть согласия, удалить нельзя).
model UserConsent {
  id                String        @id @default(uuid())
  userId            String
  documentVersionId String
  consentType       ConsentType
  action            ConsentAction
  ip                String?
  userAgent         String?
  createdAt         DateTime      @default(now())

  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentVersion LegalDocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([documentVersionId])
}
