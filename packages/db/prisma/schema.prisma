generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  student
  admin
}

enum StreamStatus {
  active
  archived
}

enum LessonStatus {
  draft
  published
  closed
}

enum AssignmentType {
  short
  long
}

enum StudentAssignmentStatus {
  assigned
  submitted
  reviewed
  needs_revision
}

enum ThreadEntryType {
  text
  file
  audio
  link
  comment
  note
}

enum NotificationType {
  lesson_published
  assignment_created
  deadline_reminder
  thread_entry
  assignment_submitted
  assignment_reviewed
  schedule_entry_created
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  passwordHash       String
  role               UserRole  @default(student)
  name               String
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(false)
  inviteToken        String?   @unique
  inviteExpiresAt    DateTime?
  resetToken         String?   @unique
  resetTokenExpiresAt DateTime?
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  refreshTokens           RefreshToken[]
  studentAssignments      StudentAssignment[]
  thread                  Thread?
  threadEntries           ThreadEntry[]            @relation("AuthoredEntries")
  studentProfile          StudentProfile?
  teacherNotes            TeacherNote[]            @relation("AuthoredNotes")
  studentNotes            TeacherNote[]            @relation("StudentNotes")
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  pushSubscriptions       PushSubscription[]
  apiKeys                 ApiKey[]
}

model ApiKey {
  id         String    @id @default(uuid())
  name       String
  keyPrefix  String
  keyHash    String    @unique
  userId     String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Stream {
  id        String       @id @default(uuid())
  name      String
  status    StreamStatus @default(active)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  lessons         Lesson[]
  assignments     Assignment[]
  scheduleEntries ScheduleEntry[]
}

model Lesson {
  id        String       @id @default(uuid())
  streamId  String
  title     String
  videoUrl  String?
  summary   String?
  notes     String?
  status    LessonStatus @default(draft)
  publishAt DateTime?
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  stream      Stream       @relation(fields: [streamId], references: [id], onDelete: Cascade)
  assignments Assignment[]

  @@index([streamId])
}

model Assignment {
  id          String         @id @default(uuid())
  lessonId    String?
  streamId    String
  title       String
  description String?
  type        AssignmentType @default(short)
  tags        String[]       @default([])
  dueDate     DateTime?
  groupId     String?
  materials   Json           @default("[]")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  lesson             Lesson?             @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  stream             Stream              @relation(fields: [streamId], references: [id], onDelete: Cascade)
  studentAssignments StudentAssignment[]
  threadEntries      ThreadEntry[]

  @@index([streamId])
  @@index([lessonId])
}

model StudentAssignment {
  id             String                  @id @default(uuid())
  assignmentId   String
  studentId      String
  status         StudentAssignmentStatus @default(assigned)
  content        String?
  fileUrl        String?
  fileName       String?
  fileSize       Int?
  studentComment String?
  submittedAt    DateTime?
  reviewedAt     DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([studentId])
}

model Thread {
  id        String   @id @default(uuid())
  studentId String   @unique
  createdAt DateTime @default(now())

  student User          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  entries ThreadEntry[]
}

model ThreadEntry {
  id           String          @id @default(uuid())
  threadId     String
  authorId     String
  type         ThreadEntryType @default(text)
  content      String
  metadata     Json?
  assignmentId String?
  createdAt    DateTime        @default(now())
  readAt       DateTime?

  thread     Thread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author     User        @relation("AuthoredEntries", fields: [authorId], references: [id], onDelete: Cascade)
  assignment Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)

  @@index([threadId])
  @@index([authorId])
}

model StudentProfile {
  id                       String    @id @default(uuid())
  studentId                String    @unique
  resume                   String?
  portfolio                String?
  contacts                 Json?
  direction                String?
  questionnaireCompletedAt DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model TeacherNote {
  id        String   @id @default(uuid())
  studentId String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  student User @relation("StudentNotes", fields: [studentId], references: [id], onDelete: Cascade)
  author  User @relation("AuthoredNotes", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model ScheduleEntry {
  id          String   @id @default(uuid())
  streamId    String
  date        DateTime @db.Date
  startTime   String
  lessonTitle String
  notes       String?
  meetingUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stream Stream @relation(fields: [streamId], references: [id], onDelete: Cascade)

  @@index([streamId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  metadata  Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model NotificationPreference {
  id           String           @id @default(uuid())
  userId       String
  type         NotificationType
  emailEnabled Boolean          @default(true)
  pushEnabled  Boolean          @default(true)
  inAppEnabled Boolean          @default(true)
  updatedAt    DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
