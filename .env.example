# === Database ===
# PostgreSQL connection string
DATABASE_URL="postgresql://platform:platform@localhost:5432/platform?schema=public"

# === API Server ===
# Port for the Fastify API server
PORT=4000
# Host binding
HOST=0.0.0.0
# Allowed CORS origin (frontend URL)
CORS_ORIGIN=http://localhost:3000

# === Auth (for future use in task 1.2) ===
# JWT secret for signing access tokens
JWT_SECRET="change-me-in-production"
# JWT access token expiry
JWT_EXPIRES_IN="15m"
# JWT refresh token expiry
JWT_REFRESH_EXPIRES_IN="7d"

# === MinIO / S3 ===
# Запустите MinIO перед использованием: pnpm dev:services
# S3-compatible storage endpoint
S3_ENDPOINT=http://localhost:9000
# S3 access key
S3_ACCESS_KEY=minioadmin
# S3 secret key
S3_SECRET_KEY=minioadmin
# S3 bucket name for file uploads
S3_BUCKET=platform-uploads
# S3 region (MinIO ignores this but SDK requires it)
S3_REGION=us-east-1

# === SMTP (email for password reset) ===
# For Resend: SMTP_HOST=smtp.resend.com, SMTP_PORT=465, SMTP_USER=resend, SMTP_PASS=<API_KEY>
# For Brevo:  SMTP_HOST=smtp-relay.brevo.com, SMTP_PORT=587, SMTP_USER=<email>, SMTP_PASS=<SMTP_KEY>
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@platform.local
# SMTP auth credentials (required for production providers like Resend, Brevo, SendGrid)
SMTP_USER=
SMTP_PASS=

# === Frontend (web, server-side) ===
# API base URL the Next.js server uses for the /api-proxy route and SSR.
# Runtime variable (no NEXT_PUBLIC_ prefix) — change without rebuilding the image.
API_URL=http://localhost:4000
