xn--90ad2cb.xn--p1ai, xn--0-8sbf7bfq.xn--p1ai {
    # Публичный вебхук Zoom: проксируем напрямую в API, минуя Next.js.
    # handle (а не handle_path) — чтобы префикс /webhooks НЕ срезался и API
    # получил полный путь /webhooks/zoom/:webhookId. Тело запроса передаётся
    # как есть (сырое для HMAC), Caddy его не буферизирует и не модифицирует.
    handle /webhooks/* {
        reverse_proxy api:4000
    }

    # Файлы хранилища — НАПРЯМУЮ в API (подписанные URL stateless), минуя Next.
    # iframe/img/fetch грузят /files/... same-origin без хрупкого /api-proxy
    # (тот на проде не доносил /api-proxy/files/... до Next-обработчика → 404).
    handle /files/* {
        reverse_proxy api:4000
    }

    # Всё остальное — на Next.js, как раньше.
    handle {
        reverse_proxy web:3000
    }
}
